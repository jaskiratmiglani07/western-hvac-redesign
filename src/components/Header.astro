---
// src/components/Header.astro
---

<header class="site-header glass">
  <div class="container header-container">
    <!-- Brand Logo -->
    <a href="/" class="logo-group">
      <div class="logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 22h20L12 2z"/>
          <path d="M12 18V6"/>
        </svg>
      </div>
      <div class="logo-text">
        <span class="brand-name">WESTERN</span>
        <span class="brand-sub">HEATING • COOLING • PLUMBING • ELECTRICAL</span>
      </div>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="nav-desktop">
      <a href="#services" class="nav-link">Services</a>
      <a href="#why-choose-us" class="nav-link">Why Choose Us</a>
      <a href="#reviews" class="nav-link">Reviews</a>
      <a href="#financing" class="nav-link">Financing</a>
      <a href="#faq" class="nav-link">FAQ</a>
    </nav>

    <!-- Navigation CTAs -->
    <div class="header-ctas">
      <a href="tel:2082040357" class="phone-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <span>(208) 204-0357</span>
      </a>
      <a href="#schedule" class="btn btn-primary btn-sm schedule-btn">Schedule Service</a>
      
      <!-- Mobile menu trigger -->
      <button class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div class="nav-mobile-dropdown">
    <nav class="nav-mobile-links">
      <a href="#services" class="mobile-nav-link">Services</a>
      <a href="#why-choose-us" class="mobile-nav-link">Why Choose Us</a>
      <a href="#reviews" class="mobile-nav-link">Reviews</a>
      <a href="#financing" class="mobile-nav-link">Financing</a>
      <a href="#faq" class="mobile-nav-link">FAQ</a>
      
      <div class="mobile-dropdown-divider"></div>
      
      <a href="tel:2082040357" class="mobile-phone-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <span>(208) 204-0357</span>
      </a>
      <a href="#schedule" class="btn btn-primary mobile-schedule-btn">Schedule Service</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    transition: background-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .header-container {
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .logo-group {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .logo-icon {
    width: 42px;
    height: 42px;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--rounded-md);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(185, 28, 28, 0.2);
    transition: transform var(--transition-fast);
  }

  .logo-icon svg {
    width: 24px;
    height: 24px;
    transform: rotate(45deg);
  }

  .logo-group:hover .logo-icon {
    transform: rotate(5deg) scale(1.05);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-size: 24px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .brand-sub {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-top: 2px;
  }

  /* Desktop Nav Links */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .nav-link {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink-soft);
    position: relative;
    padding: var(--spacing-xs) 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-normal);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Header CTAs */
  .header-ctas {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .phone-link {
    display: none;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .phone-link:hover {
    color: var(--color-primary);
  }

  .phone-link svg {
    color: var(--color-primary);
  }

  .schedule-btn {
    display: none;
  }

  /* Mobile menu button */
  .mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger-bar {
    width: 100%;
    height: 3px;
    background-color: var(--color-ink);
    border-radius: 4px;
    transition: transform var(--transition-normal), opacity var(--transition-normal);
  }

  /* Active states for mobile menu toggle */
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* Mobile Dropdown */
  .nav-mobile-dropdown {
    display: block;
    position: absolute;
    top: 80px;
    left: 0;
    width: 100%;
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal) cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-lg);
  }

  .nav-mobile-dropdown.open {
    max-height: 400px;
  }

  .nav-mobile-links {
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .mobile-nav-link {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-ink);
    padding: var(--spacing-xs) 0;
  }

  .mobile-dropdown-divider {
    height: 1px;
    background-color: var(--color-border-light);
    margin: var(--spacing-xs) 0;
  }

  .mobile-phone-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .mobile-phone-link svg {
    color: var(--color-primary);
  }

  .mobile-schedule-btn {
    width: 100%;
  }

  /* Responsiveness */
  @media (min-width: 768px) {
    .phone-link {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
    .schedule-btn {
      display: inline-flex;
    }
    .mobile-menu-toggle {
      display: none;
    }
    .nav-mobile-dropdown {
      display: none;
    }
  }
</style>

<script>
  const toggleBtn = document.querySelector('.mobile-menu-toggle');
  const mobileDropdown = document.querySelector('.nav-mobile-dropdown');
  const header = document.querySelector('.site-header');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  // Toggle mobile dropdown
  if (toggleBtn && mobileDropdown) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      mobileDropdown.classList.toggle('open');
    });

    // Close mobile dropdown when a link is clicked
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.setAttribute('aria-expanded', 'false');
        mobileDropdown.classList.remove('open');
      });
    });
  }

  // Scroll effect to make navigation background solid
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-nav');
      header?.setAttribute('style', 'background-color: rgba(255, 254, 251, 0.92); box-shadow: 0 4px 30px rgba(32, 21, 21, 0.05); border-bottom: 1px solid var(--color-border-light);');
    } else {
      header?.classList.remove('shadow-nav');
      header?.setAttribute('style', '');
    }
  });
</script>
