---
// src/components/FAQ.astro

const faqs = [
  {
    question: "Do you charge extra for emergency or weekend service calls?",
    answer: "No! At Western, we believe home emergencies don't wait for business hours. We offer 24/7 emergency dispatch for heating, cooling, plumbing, and electrical issues with no extra hidden after-hours fees. The price we quote is the price you pay."
  },
  {
    question: "How do I know if my AC or furnace needs repair vs. full replacement?",
    answer: "Generally, we follow the 'rule of 5,000': multiply the age of your system by the repair cost. If it exceeds $5,000, or if your system is over 12-15 years old and experiencing frequent issues, replacement is usually the most cost-effective long-term option. We provide upfront diagnostics to help you make an informed decision."
  },
  {
    question: "How often should I service my heating and cooling systems?",
    answer: "We strongly recommend servicing your systems twice a year: once in the spring for your air conditioner, and once in the autumn for your heating system/furnace. Regular tune-ups keep your utility bills low, extend the life of your equipment, and maintain manufacturer warranty validity."
  },
  {
    question: "What areas in Idaho do you service?",
    answer: "We proudly serve residential and commercial customers throughout the entire Treasure Valley area. This includes Boise, Meridian, Eagle, Nampa, Caldwell, Star, Kuna, and surrounding communities."
  },
  {
    question: "Can I get an estimate for a new system replacement?",
    answer: "Yes! We offer 100% free, no-obligation estimates on new furnace, heat pump, air conditioning, and electrical panel replacements. One of our home comfort specialists will visit your house, analyze your load requirements, and present customized options with clear financing terms."
  }
];
---

<section id="faq" class="faq-section">
  <div class="container">
    
    <!-- Header Block -->
    <div class="section-header text-center">
      <div class="badge faq-eyebrow">COMMON QUESTIONS</div>
      <h2 class="section-title">Homeowner FAQ</h2>
      <p class="section-desc lead">
        Have questions about scheduling, pricing, or emergency service? Here are answers to questions Boise residents ask most often.
      </p>
    </div>

    <!-- FAQ Accordion Layout -->
    <div class="faq-accordion-container">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <span class="faq-arrow-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  .faq-section {
    background-color: var(--color-canvas-soft);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  .text-center {
    text-align: center;
    align-items: center;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--spacing-3xl);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .faq-eyebrow {
    background-color: var(--color-canvas);
    border-color: var(--color-border);
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .section-title {
    margin-bottom: var(--spacing-md);
  }

  /* Accordion styling */
  .faq-accordion-container {
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .faq-item {
    background-color: var(--color-canvas);
    border: 1px solid var(--color-border-light);
    border-radius: var(--rounded-md);
    overflow: hidden;
    transition: all var(--transition-normal);
  }

  .faq-item[open] {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-xl);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-ink);
    cursor: pointer;
    list-style: none; /* Hide default summary arrow */
    user-select: none;
    transition: color var(--transition-fast);
  }

  /* Hide default Webkit summary marker */
  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    color: var(--color-primary);
  }

  .faq-arrow-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--rounded-full);
    background-color: var(--color-canvas-soft);
    color: var(--color-ink-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-question .faq-arrow-icon {
    transform: rotate(180deg);
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .faq-answer {
    padding: 0 var(--spacing-xl) var(--spacing-xl) var(--spacing-xl);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-body);
  }

  .faq-answer p {
    margin-bottom: 0;
  }
</style>
