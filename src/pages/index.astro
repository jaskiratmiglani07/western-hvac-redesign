---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Reviews from '../components/Reviews.astro';
import Financing from '../components/Financing.astro';
import FAQ from '../components/FAQ.astro';
import AIAssistant from '../components/AIAssistant.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Western Heating, Air Conditioning, Electrical & Plumbing | Boise, ID" description="Serving Boise, Meridian, Eagle, and Nampa since 1967. Reliable heating, cooling, plumbing, and electrical services. Same-day emergency service available.">
  <!-- Sticky Header -->
  <Header />

  <!-- Main Content Sections -->
  <main>
    <!-- Hero Section -->
    <Hero />

    <!-- Services Grid -->
    <Services />

    <!-- Why Choose Us Highlights -->
    <WhyChooseUs />

    <!-- Reviews Testimonial Slider -->
    <Reviews />

    <!-- Financing Options -->
    <Financing />

    <!-- FAQ Accordion -->
    <FAQ />

    <!-- Interactive Schedule Service Section -->
    <section id="schedule" class="schedule-section">
      <div class="container schedule-container">
        <!-- Info Column -->
        <div class="schedule-info">
          <div class="badge schedule-eyebrow">BOOK APPOINTMENT</div>
          <h2 class="schedule-title">Easy Online Scheduling</h2>
          <p class="lead schedule-desc">
            Schedule a certified HVAC specialist, electrician, or plumber to visit your home. Select a date and time that fits your day.
          </p>
          
          <div class="info-card glass">
            <h4>What happens next?</h4>
            <ul class="steps-list">
              <li>
                <span class="step-num">1</span>
                <div>
                  <strong>Dispatcher Call-back</strong>
                  <span>We will call you in minutes to verify details and lock in your window.</span>
                </div>
              </li>
              <li>
                <span class="step-num">2</span>
                <div>
                  <strong>Technician Tracker</strong>
                  <span>You'll receive a text tracker with your technician's photo and exact ETA.</span>
                </div>
              </li>
              <li>
                <span class="step-num">3</span>
                <div>
                  <strong>Upfront Pricing</strong>
                  <span>Your technician diagnoses the issue and quotes a flat rate before any work begins.</span>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Form Column -->
        <div class="schedule-form-wrapper">
          <form class="schedule-form card" id="booking-form">
            <div class="form-grid">
              <div class="form-group">
                <label for="client-name">Your Full Name</label>
                <input type="text" id="client-name" name="name" placeholder="John Doe" required />
              </div>
              <div class="form-group">
                <label for="client-phone">Phone Number</label>
                <input type="tel" id="client-phone" name="phone" placeholder="(208) 555-0123" required />
              </div>
              <div class="form-group">
                <label for="client-email">Email Address</label>
                <input type="email" id="client-email" name="email" placeholder="john@example.com" required />
              </div>
              <div class="form-group">
                <label for="service-type">Required Service</label>
                <select id="service-type" name="service" required>
                  <option value="" disabled selected>Select a Service</option>
                  <option value="cooling">Air Conditioning / Cooling</option>
                  <option value="heating">Heating / Furnace</option>
                  <option value="plumbing">Plumbing Services</option>
                  <option value="electrical">Electrical Services</option>
                  <option value="iaq">Indoor Air Quality</option>
                </select>
              </div>
              <div class="form-group full-width">
                <label for="booking-date">Preferred Date</label>
                <input type="date" id="booking-date" name="date" required />
              </div>
              <div class="form-group full-width">
                <label for="problem-desc">Tell us what's going on</label>
                <textarea id="problem-desc" name="message" rows="3" placeholder="Explain the problem briefly..."></textarea>
              </div>
            </div>
            
            <button type="submit" class="btn btn-primary submit-btn">Confirm Service Appointment</button>
          </form>

          <!-- Success message overlay (hidden initially) -->
          <div class="form-success-card card" id="booking-success" style="display: none;">
            <div class="success-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3>Appointment Requested!</h3>
            <p>
              Thank you, <span id="success-name">Customer</span>. We've received your booking request for <strong id="success-service">service</strong> on <span id="success-date">your date</span>.
            </p>
            <p class="success-note">
              A Western dispatcher will call you shortly at <span id="success-phone">your phone</span> to lock in your arrival time.
            </p>
            <button class="btn btn-outline reset-form-btn" id="success-done-btn">Done</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Final High-Converting CTA Banner Section -->
    <section class="final-cta-section">
      <div class="container final-cta-container">
        <h2 class="final-cta-title">Need Reliable HVAC, Plumbing or Electrical Service Today?</h2>
        <p class="lead final-cta-text">
          Don't wait for issues to get worse. Our technicians are local, background-checked, and ready to resolve your problems immediately.
        </p>
        <div class="final-cta-actions">
          <a href="#schedule" class="btn btn-primary btn-lg">Schedule Online Now</a>
          <a href="tel:2082040357" class="btn btn-outline btn-lg final-phone-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>Call (208) 204-0357</span>
          </a>
        </div>
        <p class="final-cta-footer">
          ⚡ Average technician arrival time is under 2 hours for urgent calls.
        </p>
      </div>
    </section>
  </main>

  <!-- Floating AI Assistant -->
  <AIAssistant />

  <!-- Footer Info Block -->
  <Footer />
</Layout>

<style>
  /* Schedule Section */
  .schedule-section {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  .schedule-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3xl);
    align-items: flex-start;
  }

  /* Info Column */
  .schedule-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .schedule-eyebrow {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-border);
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .schedule-title {
    margin-bottom: var(--spacing-md);
  }

  .schedule-desc {
    margin-bottom: var(--spacing-2xl);
    color: var(--color-body);
  }

  /* Next steps box */
  .info-card {
    border-radius: var(--rounded-md);
    padding: var(--spacing-xl);
    width: 100%;
    border: 1px solid var(--color-border-light);
  }

  .info-card h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-ink);
  }

  .steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .steps-list li {
    display: flex;
    gap: var(--spacing-md);
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    border-radius: var(--rounded-full);
    background-color: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 14px;
    flex-shrink: 0;
  }

  .steps-list li div {
    display: flex;
    flex-direction: column;
    line-height: 1.4;
  }

  .steps-list li div strong {
    font-size: 16px;
    color: var(--color-ink);
  }

  .steps-list li div span {
    font-size: 14.5px;
    color: var(--color-body);
  }

  /* Form Column */
  .schedule-form-wrapper {
    position: relative;
    width: 100%;
  }

  .schedule-form {
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-border-light);
    border-radius: var(--rounded-md);
    padding: var(--spacing-2xl);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--font-sans);
    font-size: 15px;
    padding: 10px 14px;
    border-radius: var(--rounded-sm);
    border: 1px solid var(--color-border);
    background-color: var(--color-white);
    color: var(--color-ink);
    outline: none;
    transition: all var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.1);
  }

  .submit-btn {
    width: 100%;
  }

  /* Form Success Card Override */
  .form-success-card {
    background-color: var(--color-white);
    border: 1px solid #a7f3d0;
    padding: var(--spacing-3xl) var(--spacing-2xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: var(--rounded-md);
    box-shadow: var(--shadow-lg);
  }

  .success-icon {
    width: 56px;
    height: 56px;
    background-color: #ecfdf5;
    color: #10b981;
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-lg);
  }

  .success-icon svg {
    width: 28px;
    height: 28px;
  }

  .form-success-card h3 {
    margin-bottom: var(--spacing-sm);
    color: var(--color-ink);
  }

  .form-success-card p {
    font-size: 16px;
    margin-bottom: var(--spacing-sm);
    color: var(--color-body);
  }

  .success-note {
    font-size: 14.5px;
    background-color: var(--color-canvas-soft);
    padding: var(--spacing-md);
    border-radius: var(--rounded-md);
    width: 100%;
    margin-bottom: var(--spacing-xl) !important;
  }

  .reset-form-btn {
    width: 120px;
  }

  /* Final CTA banner */
  .final-cta-section {
    background-color: var(--color-ink);
    color: var(--color-white);
    text-align: center;
    padding-top: var(--spacing-5xl);
    padding-bottom: var(--spacing-5xl);
  }

  .final-cta-container {
    max-width: 820px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final-cta-title {
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .final-cta-text {
    color: #d1d5db;
    margin-bottom: var(--spacing-3xl);
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    justify-content: center;
    width: 100%;
    margin-bottom: var(--spacing-xl);
  }

  .final-cta-actions .btn {
    flex: 1 1 100%;
  }

  .final-phone-btn {
    border-color: #4b5563;
    color: var(--color-white);
  }

  .final-phone-btn:hover {
    border-color: var(--color-white);
    background-color: #27272a;
  }

  .final-phone-btn svg {
    color: var(--color-primary);
  }

  .final-cta-footer {
    font-size: 14px;
    color: #9ca3af;
    margin-bottom: 0;
    font-weight: 500;
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .form-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .form-group.full-width {
      grid-column: span 2;
    }
    
    .final-cta-actions .btn {
      flex: 0 0 auto;
      width: auto;
    }
  }

  @media (min-width: 1024px) {
    .schedule-container {
      grid-template-columns: 0.95fr 1.05fr;
      gap: var(--spacing-4xl);
    }
  }
</style>

<script>
  // Booking Form Submission Handler
  const bookingForm = document.getElementById('booking-form') as HTMLFormElement;
  const bookingSuccess = document.getElementById('booking-success') as HTMLElement;
  const successName = document.getElementById('success-name');
  const successService = document.getElementById('success-service');
  const successDate = document.getElementById('success-date');
  const successPhone = document.getElementById('success-phone');
  const doneBtn = document.getElementById('success-done-btn');

  // Set minimum date input to today
  const dateInput = document.getElementById('booking-date') as HTMLInputElement;
  if (dateInput) {
    const today = new Date().toISOString().split('T')[0];
    dateInput.min = today;
    dateInput.value = today;
  }

  if (bookingForm && bookingSuccess) {
    bookingForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(bookingForm);
      const name = formData.get('name') as string;
      const phone = formData.get('phone') as string;
      const service = formData.get('service') as string;
      const date = formData.get('date') as string;

      // Map service slugs to display text
      const serviceDisplayMap: Record<string, string> = {
        cooling: "Air Conditioning",
        heating: "Heating/Furnace Repair",
        plumbing: "Plumbing Service",
        electrical: "Electrical Work",
        iaq: "Indoor Air Quality"
      };

      // Form fill elements
      if (successName) successName.innerText = name;
      if (successService) successService.innerText = serviceDisplayMap[service] || "Home Service";
      if (successDate) successDate.innerText = date;
      if (successPhone) successPhone.innerText = phone;

      // Show success screen
      bookingForm.style.display = 'none';
      bookingSuccess.style.display = 'flex';
      
      // Optional: Scroll to target
      bookingSuccess.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  doneBtn?.addEventListener('click', () => {
    if (bookingForm && bookingSuccess) {
      bookingForm.reset();
      bookingForm.style.display = 'block';
      bookingSuccess.style.display = 'none';
      
      // Reset default date value
      if (dateInput) {
        const today = new Date().toISOString().split('T')[0];
        dateInput.value = today;
      }
    }
  });
</script>
