---
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Western Heating, Air Conditioning, Electrical & Plumbing | Boise, ID", 
	description = "Serving Boise, Idaho since 1967. Professional heating, air conditioning, plumbing, electrical, and indoor air quality services. 24/7 emergency service, licensed and insured." 
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / Social Media -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/hero_technician.png" />
		
		<!-- Font preloads or scripts can go here -->
	</head>
	<body>
		<slot />
	</body>
</html>
